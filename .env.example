# Vouch configuration — copy to .env and fill in.
# NEVER commit .env. Values below are placeholders.

# HTTP
PORT=8787

# x402 payment challenge (filled once the Agentic Wallet is set up)
# X Layer chain: eip155:196 (gas-free).
PAY_TO_ADDRESS=            # our Agentic Wallet EVM address (from `onchainos wallet addresses`, xlayer entry)
USDT_ASSET=0x779Ded0c9e1022225f8E0630b35a9b54bE713736  # USDT0 (USD₮0), the canonical USDT on X Layer — confirmed via onchainos token search + X Layer's own docs (2026-07-06). NOT 0x1e4a5963...: that's the old, deprecated wrapped USDT.
USDT_DECIMALS=6

# Per-call prices, in USDT base units (6 decimals -> 1_000_000 = 1 USDT)
PRICE_COMPILE_SPEC=50000       # 0.05 USDT
PRICE_INSPECT_DELIVERY=250000  # 0.25 USDT
PRICE_EVIDENCE_PACK=500000     # 0.50 USDT

# Public base URL of the deployed service (permanent on-chain once registered)
PUBLIC_BASE_URL=http://localhost:8787

# compile_spec (the LLM spec compiler) needs this. Get one at console.anthropic.com.
# Without it, /compile_spec returns 503 but everything else still works.
ANTHROPIC_API_KEY=

# Set to 1 for local/dev use to bypass the x402 payment gate entirely
# (no wallet needed). NEVER set this in a deployed/production environment.
ALLOW_UNPAID=
